generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id          String   @id @default(uuid())
  name        String   
  description String?  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  members     WorkspaceMember[]
  tasks       Task[]
  clients     Client[]
  projects    Project[]
  invoices    Invoice[]
  payrolls    Payroll[]
  metrics     PerformanceMetric[]

  @@index([name])
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  role        String   @default("MEMBER") // "OWNER", "ADMIN", "MEMBER", "GUEST"
  joinedAt    DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
}

model User {
  id                String              @id @default(uuid())
  username          String              @unique
  password          String
  plainPassword     String?
  createdAt         DateTime            @default(now())
  reputation        Int                 @default(100)
  isTreasurer       Boolean             @default(false)
  email             String?
  nickname          String?
  phoneNumber       String?
  paymentAccountNum String?
  paymentBankName   String?
  paymentQrUrl      String?
  agencyId          String?
  role              UserRole            @default(USER)
  ownedAgency       Agency[]            @relation("AgencyOwner")
  bonuses           MonthlyBonus[]
  payrolls          Payroll[]
  metrics           PerformanceMetric[]
  tasks             Task[]
  agency            Agency?             @relation("AgencyMembers", fields: [agencyId], references: [id])
  workspaces        WorkspaceMember[]
}

model Payroll {
  id          String    @id @default(uuid())
  userId      String
  month       Int
  year        Int
  baseSalary  Decimal   @default(0)
  bonus       Decimal   @default(0)
  totalAmount Decimal
  status      String    @default("UNPAID")
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  @@unique([userId, month, year])
}

model Task {
  id                 String            @id @default(uuid())
  title              String
  deadline           DateTime?
  value              Decimal           @default(0)
  status             String            @default("Đang thực hiện")
  type               String            @default("Short form")
  references         String?
  resources          String?
  notes              String?
  fileLink           String?
  assigneeId         String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  productLink        String?
  isPenalized        Boolean           @default(false)
  exchangeRate       Decimal?          @default(25300)
  jobPriceUSD        Decimal?          @default(0)
  profitVND          Decimal?          @default(0)
  wageVND            Decimal?          @default(0)
  projectId          Int?
  clientId           Int?
  collectFilesLink   String?
  assignedAgencyId   String?
  version            Int               @default(0)
  invoiceId          String?
  invoiceStatus      InvoiceTaskStatus @default(UNBILLED)
  isArchived         Boolean           @default(false)
  feedbacks          Feedback[]
  invoiceItems       InvoiceItem[]
  assignedAgency     Agency?           @relation(fields: [assignedAgencyId], references: [id])
  assignee           User?             @relation(fields: [assigneeId], references: [id])
  client             Client?           @relation(fields: [clientId], references: [id])
  invoice            Invoice?          @relation(fields: [invoiceId], references: [id])
  project            Project?          @relation(fields: [projectId], references: [id])
  workspaceId        String?
  workspace          Workspace?        @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, status])
  @@index([workspaceId, isArchived])
}


model MonthlyBonus {
  id                 String   @id @default(uuid())
  userId             String
  month              Int
  year               Int
  rank               Int
  revenue            Decimal
  executionTimeHours Float
  bonusAmount        Decimal
  calculatedAt       DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id])

  @@unique([userId, month, year])
}

model PayrollLock {
  id       String   @id @default(uuid())
  month    Int
  year     Int
  isLocked Boolean  @default(false)
  lockedAt DateTime @default(now())
  lockedBy String

  @@unique([month, year])
}

model Client {
  id             Int        @id @default(autoincrement())
  name           String
  parentId       Int?
  aiScore        Decimal    @default(0)
  frictionIndex  Decimal    @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  inputQuality   Int        @default(3)
  paymentRating  Int        @default(3)
  tier           ClientTier @default(standard)
  depositBalance Decimal    @default(0)
  parent         Client?    @relation("ClientHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  subsidiaries   Client[]   @relation("ClientHierarchy")
  invoices       Invoice[]
  projects       Project[]
  tasks          Task[]
  workspaceId    String?
  workspace      Workspace? @relation(fields: [workspaceId], references: [id])
}

model Project {
  id        Int        @id @default(autoincrement())
  name      String
  code      String?
  clientId  Int
  createdAt DateTime   @default(now())
  feedbacks Feedback[]
  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks     Task[]
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
}

model Feedback {
  id        Int            @id @default(autoincrement())
  content   String
  projectId Int?
  severity  Int            @default(1)
  createdAt DateTime       @default(now())
  taskId    String?
  type      FeedbackSource @default(CLIENT)
  project   Project?       @relation(fields: [projectId], references: [id])
  task      Task?          @relation(fields: [taskId], references: [id])
}

model PerformanceMetric {
  id                    String   @id @default(uuid())
  userId                String
  month                 Int
  year                  Int
  revenue               Decimal  @default(0)
  avgCompletionTime     Int      @default(0)
  onTimeRate            Float    @default(100)
  internalRevisionCount Int      @default(0)
  clientRevisionCount   Int      @default(0)
  score                 Float    @default(0)
  classification        String   @default("NORMAL")
  measuredAt            DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id])
  workspaceId           String?
  workspace             Workspace? @relation(fields: [workspaceId], references: [id])

  @@unique([userId, month, year])
}


model Agency {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  ownerId   String?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User?    @relation("AgencyOwner", fields: [ownerId], references: [id])
  tasks     Task[]
  members   User[]   @relation("AgencyMembers")
}


model BillingProfile {
  id              String   @id @default(uuid())
  profileName     String
  beneficiaryName String
  bankName        String
  accountNumber   String
  swiftCode       String?
  address         String?
  isDefault       Boolean  @default(false)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
  notes           String?
}

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique
  clientId        Int
  createdBy       String
  issueDate       DateTime      @default(now())
  dueDate         DateTime?
  subtotalAmount  Decimal       @default(0)
  depositDeducted Decimal       @default(0)
  taxPercent      Decimal       @default(0)
  taxAmount       Decimal       @default(0)
  totalDue        Decimal       @default(0)
  status          InvoiceStatus @default(DRAFT)
  filePath        String?
  fileCreatedAt   DateTime?
  billingSnapshot Json
  clientSnapshot  Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  client          Client        @relation(fields: [clientId], references: [id])
  items           InvoiceItem[]
  tasks           Task[]
  workspaceId     String?
  workspace       Workspace?     @relation(fields: [workspaceId], references: [id])
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  taskId      String?
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @default(0)
  amount      Decimal @default(0)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  task        Task?   @relation(fields: [taskId], references: [id])
}

enum FeedbackSource {
  INTERNAL
  CLIENT
}

enum ClientTier {
  DIAMOND
  GOLD
  SILVER
  WARNING
  standard
}


enum UserRole {
  ADMIN
  USER
  AGENCY_ADMIN
  LOCKED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum InvoiceTaskStatus {
  UNBILLED
  INVOICED
}
