# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# nested node_modules (electron/, mcp-server/) — root /node_modules above is anchored to root only
**/node_modules/

# desktop (Electron) + MCP server build artifacts (keep source, drop builds)
/electron/dist/
/electron/release/
/mcp-server/dist/
/mcp-server/build/

# stray junk / transient locks
/null
.claude/scheduled_tasks.lock
