// [Chat Phase 2] Custom workspace roles (org tiers: Manager, Editor, Client…) — a
// lighter alternative to Discord's bitfield. Channel access is refined per-channel via
// ChannelOverwrite. Distinct from the WorkspaceRole enum (OWNER/ADMIN/MEMBER/GUEST).
model CustomRole {
  id          String   @id @default(cuid())
  workspaceId String
  profileId   String
  name        String
  color       String?
  position    Int      @default(0)
  createdAt   DateTime @default(now())

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   CustomRoleMember[]

  @@index([workspaceId, position])
}

model CustomRoleMember {
  id          String @id @default(cuid())
  workspaceId String
  roleId      String
  userId      String

  role CustomRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roleId, userId])
  @@index([userId])
  @@index([workspaceId])
}

// [Chat Phase 2] Per-channel ALLOW/DENY overwrite for a role OR a user. allow/deny are
// CSV action sets (e.g. "VIEW,POST"). No row = pure membership behaviour (identical to
// pre-Phase-2). Precedence in the resolver: base(membership) → role → user; deny→allow.
model ChannelOverwrite {
  id          String @id @default(cuid())
  workspaceId String
  channelId   String
  subjectType String // 'ROLE' | 'USER'
  subjectId   String // CustomRole.id or User.id
  allow       String @default("")
  deny        String @default("")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, subjectType, subjectId])
  @@index([channelId])
}

// [Chat Phase 3] OpenGraph link preview cached per message (filled async after send).
model LinkPreview {
  id          String   @id @default(cuid())
  workspaceId String
  messageId   String
  url         String
  title       String?
  description String?  @db.Text
  imageUrl    String?
  siteName    String?
  createdAt   DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model WikiPage {
  id          String   @id @default(cuid())
  workspaceId String
  profileId   String
  channelId   String?
  parentId    String?
  title       String
  icon        String?
  content     String   @db.Text // Tiptap HTML document
  position    Int      @default(0)
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel     Channel?     @relation(fields: [channelId], references: [id], onDelete: SetNull)
  parent      WikiPage?    @relation("WikiTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    WikiPage[]   @relation("WikiTree")
  author      User         @relation(fields: [authorId], references: [id])
  attachments Attachment[]

  @@index([workspaceId])
  @@index([parentId])
}

model Attachment {
  id          String   @id @default(cuid())
  workspaceId String
  profileId   String
  messageId   String?
  wikiPageId  String?
  url         String
  fileName    String
  mimeType    String
  sizeBytes   Int
  width       Int?
  height      Int?
  createdAt   DateTime @default(now())

  message  Message?  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  wikiPage WikiPage? @relation(fields: [wikiPageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([wikiPageId])
}

// ============================================================
// PAYROLL BONUS CONFIG — cấu hình tính thưởng riêng theo team (profile).
// 1 config / profile (dùng lại mọi tháng/workspace). Top 1/2/3: bật/tắt + %.
// Không có workspaceId → truy vấn bằng prisma thường (lọc profileId), KHÔNG
// qua getWorkspacePrisma.
// ============================================================
model BonusConfig {
  id          String   @id @default(cuid())
  profileId   String   @unique
  top1Enabled Boolean  @default(true)
  top1Percent Decimal  @default(0)
  top2Enabled Boolean  @default(false)
  top2Percent Decimal  @default(0)
  top3Enabled Boolean  @default(false)
  top3Percent Decimal  @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}
