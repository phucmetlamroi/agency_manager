generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id        String   @id @default(uuid())
  name      String
  bannerUrl String?
  logoUrl   String?
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               User[]
  workspaces          Workspace[]
  tasks               Task[]
  clients             Client[]
  projects            Project[]
  invoices            Invoice[]
  payrolls            Payroll[]
  bonuses             MonthlyBonus[]
  payrollLocks        PayrollLock[]
  metrics             PerformanceMetric[]
  agencies            Agency[]
  errorLogs           ErrorLog[]
  monthlyRanks        MonthlyRank[]
  scheduleRules       ScheduleRule[]
  scheduleExceptions  ScheduleException[]
  dailyAvailabilities DailyAvailability[]
  profileAccesses     ProfileAccess[]
  accessRequests      ProfileAccessRequest[] @relation("TargetProfileRequests")
  billingProfiles     BillingProfile[]
  tagCategories       TagCategory[]
}

model Workspace {
  id              String   @id @default(uuid())
  name            String
  description     String?
  marketplaceOpen Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  profileId       String?

  // Soft-delete (Phase 1 multi-workspace plan, Chapter 3)
  // status defaults to ACTIVE; SOFT_DELETED workspaces hidden from switcher
  // until hard-delete cron after `hardDeleteAfter`.
  status          String    @default("ACTIVE") // see WorkspaceStatus enum: ACTIVE | SUSPENDED | SOFT_DELETED
  deletedAt       DateTime?
  hardDeleteAfter DateTime?

  members             WorkspaceMember[]
  invitations         WorkspaceInvitation[]
  tasks               Task[]
  clients             Client[]
  scheduleRules       ScheduleRule[]
  scheduleExceptions  ScheduleException[]
  dailyAvailabilities DailyAvailability[]
  projects            Project[]
  invoices            Invoice[]
  payrolls            Payroll[]
  bonuses             MonthlyBonus[]
  payrollLocks        PayrollLock[]
  metrics             PerformanceMetric[]
  feedbacks           Feedback[]
  errorLogs           ErrorLog[]
  monthlyRanks        MonthlyRank[]
  ratings             Rating[]
  sessions            Session[]
  auditLogs           AuditLog[]
  tagCategories       TagCategory[]

  profile Profile? @relation(fields: [profileId], references: [id])

  @@index([name])
  @@index([status, deletedAt])
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  role        String   @default("MEMBER") // see WorkspaceRole enum — kept as String until migration applied
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
}

model User {
  id                String              @id @default(uuid())
  username          String              @unique
  password          String
  avatarUrl         String?
  createdAt         DateTime            @default(now())
  isTreasurer       Boolean             @default(false)
  hasAcceptedTerms  Boolean             @default(false)
  termsAcceptedAt   DateTime?
  email             String?
  nickname          String?
  phoneNumber       String?
  paymentAccountNum String?
  paymentBankName   String?
  paymentQrUrl      String?
  agencyId          String?
  profileId         String?
  role              UserRole            @default(USER)
  ownedAgency       Agency[]            @relation("AgencyOwner")
  bonuses           MonthlyBonus[]
  payrolls          Payroll[]
  metrics           PerformanceMetric[]
  tasks             Task[]              @relation("AssigneeTasks")

  agency                 Agency?                 @relation("AgencyMembers", fields: [agencyId], references: [id])
  workspaces             WorkspaceMember[]
  clientTasks            Task[]                  @relation("UserClientTasks")
  clientProjects         Project[]               @relation("UserClientProjects")
  clientInvoices         Invoice[]               @relation("UserClientInvoices")
  clientRatings          Rating[]                @relation("ClientRatings")
  staffRatings           Rating[]                @relation("StaffRatings")
  errorLogs              ErrorLog[]              @relation("UserErrorLogs")
  detectedErrors         ErrorLog[]              @relation("UserDetectedErrors")
  monthlyRanks           MonthlyRank[]           @relation("UserMonthlyRanks")
  sessions               Session[]
  events                 Event[]
  presence               UserPresence?
  notificationPreference NotificationPreference?
  scheduleRules          ScheduleRule[]
  scheduleExceptions     ScheduleException[]
  dailyAvailabilities    DailyAvailability[]
  profileAccesses        ProfileAccess[]
  accessRequests         ProfileAccessRequest[]
  approvedRequests       ProfileAccessRequest[]  @relation("ApprovedBy")
  requestedRequests      ProfileAccessRequest[]  @relation("RequestedBy")
  tagCategories          TagCategory[]
  auditLogsAsActor       AuditLog[]              @relation("AuditLogActor")
  workspaceInvitesReceived WorkspaceInvitation[] @relation("WorkspaceInvitedUser")
  workspaceInvitesSent     WorkspaceInvitation[] @relation("WorkspaceInviter")

  // Chat relations
  contactsSent         Contact[]                 @relation("ContactRequester")
  contactsReceived     Contact[]                 @relation("ContactReceiver")
  chatParticipations   ConversationParticipant[]
  createdConversations Conversation[]            @relation("ConversationCreator")
  messagesSent         Message[]                 @relation("MessageSender")
  messageReactions     MessageReaction[]
  messageReadReceipts  MessageReadReceipt[]
  pinnedMessages       MessagePin[]
  notifications        Notification[]

  profile Profile? @relation(fields: [profileId], references: [id])
}

model ProfileAccess {
  id        String   @id @default(uuid())
  userId    String
  profileId String
  grantedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([userId, profileId])
}

model ProfileAccessRequest {
  id              String   @id @default(uuid())
  userId          String
  targetProfileId String
  requestedById   String
  approvedById    String?
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetProfile Profile @relation("TargetProfileRequests", fields: [targetProfileId], references: [id], onDelete: Cascade)
  requestedBy   User    @relation("RequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  approvedBy    User?   @relation("ApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@unique([userId, targetProfileId])
}

model Payroll {
  id          String    @id @default(uuid())
  userId      String
  month       Int
  year        Int
  baseSalary  Decimal   @default(0)
  bonus       Decimal   @default(0)
  totalAmount Decimal
  status      String    @default("UNPAID")
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  profileId   String?
  profile     Profile?  @relation(fields: [profileId], references: [id])

  @@unique([userId, month, year, workspaceId], name: "userId_month_year_workspaceId")
}

model Task {
  id               String            @id @default(uuid())
  title            String
  deadline         DateTime?
  value            Decimal           @default(0)
  status           String            @default("Đang thực hiện")
  type             String            @default("Short form")
  references       String?
  resources        String?
  notes_vi         String?
  notes_en         String?
  fileLink         String?
  assigneeId       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  productLink      String?
  isPenalized      Boolean           @default(false)
  exchangeRate     Decimal?          @default(25300)
  jobPriceUSD      Decimal?          @default(0)
  profitVND        Decimal?          @default(0)
  wageVND          Decimal?          @default(0)
  projectId        Int?
  clientId         Int?
  collectFilesLink String?
  submissionFolder String?
  frameUsername    String?
  framePassword    String?
  frameNote        String?           @default("Thông tin tài khoản frame dành cho trường hợp bạn bị out ra khỏi frame của team")
  assignedAgencyId String?
  version          Int               @default(0)
  invoiceId        String?
  invoiceStatus    InvoiceTaskStatus @default(UNBILLED)
  isArchived       Boolean           @default(false)
  feedbacks        Feedback[]
  errorLogs        ErrorLog[]
  invoiceItems     InvoiceItem[]
  assignedAgency   Agency?           @relation(fields: [assignedAgencyId], references: [id])
  assignee         User?             @relation("AssigneeTasks", fields: [assigneeId], references: [id])
  client           Client?           @relation(fields: [clientId], references: [id])
  clientUserId     String?
  clientUser       User?             @relation("UserClientTasks", fields: [clientUserId], references: [id])
  invoice          Invoice?          @relation(fields: [invoiceId], references: [id])
  project          Project?          @relation(fields: [projectId], references: [id])
  workspaceId      String?
  workspace        Workspace?        @relation(fields: [workspaceId], references: [id])
  profileId        String?
  profile          Profile?          @relation(fields: [profileId], references: [id])
  duration         String?
  claimSource      ClaimSource       @default(ADMIN)
  claimedAt        DateTime?
  taskTags         TaskTag[]
  rating           Rating?
  conversation     Conversation?

  @@index([workspaceId, status])
  @@index([workspaceId, isArchived])
}

model MonthlyBonus {
  id                 String    @id @default(uuid())
  userId             String
  month              Int
  year               Int
  rank               Int
  revenue            Decimal
  executionTimeHours Float
  bonusAmount        Decimal
  calculatedAt       DateTime  @default(now())
  user               User      @relation(fields: [userId], references: [id])
  workspaceId        String
  workspace          Workspace @relation(fields: [workspaceId], references: [id])
  profileId          String?
  profile            Profile?  @relation(fields: [profileId], references: [id])

  @@unique([userId, month, year, workspaceId], name: "userId_month_year_workspaceId")
}

model PayrollLock {
  id           String        @id @default(uuid())
  month        Int
  year         Int
  isLocked     Boolean       @default(false)
  lockedAt     DateTime      @default(now())
  lockedBy     String
  workspaceId  String
  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  profileId    String?
  profile      Profile?      @relation(fields: [profileId], references: [id])
  monthlyRanks MonthlyRank[]

  @@unique([month, year, workspaceId], name: "month_year_workspaceId")
}

model Client {
  id             Int        @id @default(autoincrement())
  name           String
  parentId       Int?
  aiScore        Decimal    @default(0)
  frictionIndex  Decimal    @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  inputQuality   Int        @default(3)
  paymentRating  Int        @default(3)
  tier           ClientTier @default(standard)
  depositBalance Decimal    @default(0)
  parent         Client?    @relation("ClientHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  subsidiaries   Client[]   @relation("ClientHierarchy")
  invoices       Invoice[]
  projects       Project[]
  tasks          Task[]
  workspaceId    String?
  workspace      Workspace? @relation(fields: [workspaceId], references: [id])
  profileId      String?
  profile        Profile?   @relation(fields: [profileId], references: [id])
}

model Project {
  id           Int        @id @default(autoincrement())
  name         String
  code         String?
  clientId     Int
  createdAt    DateTime   @default(now())
  feedbacks    Feedback[]
  client       Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks        Task[]
  workspaceId  String?
  workspace    Workspace? @relation(fields: [workspaceId], references: [id])
  clientUserId String?
  clientUser   User?      @relation("UserClientProjects", fields: [clientUserId], references: [id])
  profileId    String?
  profile      Profile?   @relation(fields: [profileId], references: [id])
}

model Feedback {
  id          Int            @id @default(autoincrement())
  content     String
  projectId   Int?
  severity    Int            @default(1)
  createdAt   DateTime       @default(now())
  taskId      String?
  workspaceId String?
  type        FeedbackSource @default(CLIENT)
  project     Project?       @relation(fields: [projectId], references: [id])
  task        Task?          @relation(fields: [taskId], references: [id])
  workspace   Workspace?     @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
}

model PerformanceMetric {
  id                    String    @id @default(uuid())
  userId                String
  month                 Int
  year                  Int
  revenue               Decimal   @default(0)
  avgCompletionTime     Int       @default(0)
  onTimeRate            Float     @default(100)
  internalRevisionCount Int       @default(0)
  clientRevisionCount   Int       @default(0)
  score                 Float     @default(0)
  classification        String    @default("NORMAL")
  measuredAt            DateTime  @default(now())
  user                  User      @relation(fields: [userId], references: [id])
  workspaceId           String
  workspace             Workspace @relation(fields: [workspaceId], references: [id])
  profileId             String?
  profile               Profile?  @relation(fields: [profileId], references: [id])

  @@unique([userId, month, year, workspaceId], name: "userId_month_year_workspaceId")
}

model Agency {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  ownerId   String?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User?    @relation("AgencyOwner", fields: [ownerId], references: [id])
  tasks     Task[]
  members   User[]   @relation("AgencyMembers")

  profileId String?
  profile   Profile? @relation(fields: [profileId], references: [id])
}

model BillingProfile {
  id              String   @id @default(uuid())
  profileName     String
  beneficiaryName String
  bankName        String
  accountNumber   String
  swiftCode       String?
  address         String?
  currency        String?  @default("$")
  isDefault       Boolean  @default(false)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
  notes           String?
  profileId       String?
  profile         Profile? @relation(fields: [profileId], references: [id])
}

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique
  clientId        Int
  createdBy       String
  issueDate       DateTime      @default(now())
  dueDate         DateTime?
  subtotalAmount  Decimal       @default(0)
  depositDeducted Decimal       @default(0)
  taxPercent      Decimal       @default(0)
  taxAmount       Decimal       @default(0)
  totalDue        Decimal       @default(0)
  status          InvoiceStatus @default(DRAFT)
  filePath        String?
  fileCreatedAt   DateTime?
  billingSnapshot Json
  clientSnapshot  Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  client          Client        @relation(fields: [clientId], references: [id])
  items           InvoiceItem[]
  tasks           Task[]
  workspaceId     String?
  workspace       Workspace?    @relation(fields: [workspaceId], references: [id])
  clientUserId    String?
  clientUser      User?         @relation("UserClientInvoices", fields: [clientUserId], references: [id])
  profileId       String?
  profile         Profile?      @relation(fields: [profileId], references: [id])
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  taskId      String?
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @default(0)
  amount      Decimal @default(0)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  task        Task?   @relation(fields: [taskId], references: [id])
}

/// Workspace invitation — allows OWNER/ADMIN to invite users to a workspace.
/// Supports both in-profile direct adds and cross-profile invitations with
/// accept/decline flow. Token field enables future email-based invite links.
model WorkspaceInvitation {
  id            String   @id @default(uuid())
  workspaceId   String
  invitedUserId String?  // Target user ID (set for in-app invites)
  invitedEmail  String?  // Email for future email-based invites
  role          String   @default("MEMBER") // WorkspaceRole to assign on accept
  token         String   @unique @default(uuid()) // For email/link-based invites
  status        String   @default("PENDING") // PENDING | ACCEPTED | DECLINED | EXPIRED | REVOKED
  invitedById   String   // Who sent the invite
  message       String?  // Optional personal message from inviter
  expiresAt     DateTime // When the invitation expires
  respondedAt   DateTime? // When the invitee accepted/declined
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedUser User?     @relation("WorkspaceInvitedUser", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("WorkspaceInviter", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([workspaceId, invitedUserId, status]) // Prevent duplicate pending invites
  @@index([invitedUserId, status])
  @@index([workspaceId, status])
  @@index([token])
  @@index([expiresAt])
}

/// Immutable, append-only audit trail for security-sensitive workspace events.
/// IMPORTANT: code SHOULD only INSERT. Never expose update/delete via API.
/// At the DB level we will REVOKE UPDATE/DELETE on this table from the app
/// role in Phase 2 (see migration_audit_log_revoke.sql in deploy plan).
model AuditLog {
  id          BigInt   @id @default(autoincrement())
  workspaceId String
  actorUserId String?
  action      String // e.g. 'workspace.created', 'member.role_changed', 'workspace.soft_deleted'
  targetType  String // e.g. 'WorkspaceMember', 'Workspace', 'Task'
  targetId    String?
  beforeData  Json?
  afterData   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User?     @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([action])
}

enum FeedbackSource {
  INTERNAL
  CLIENT
}

enum ClientTier {
  DIAMOND
  GOLD
  SILVER
  WARNING
  standard
}

enum UserRole {
  ADMIN
  USER
  AGENCY_ADMIN
  CLIENT
  LOCKED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum InvoiceTaskStatus {
  UNBILLED
  INVOICED
}

model Rating {
  id                  String   @id @default(cuid())
  taskId              String   @unique
  clientId            String
  staffId             String
  creativeQuality     Decimal
  responsiveness      Decimal
  communication       Decimal
  qualitativeFeedback String?  @db.Text
  createdAt           DateTime @default(now())
  workspaceId         String?

  task      Task       @relation(fields: [taskId], references: [id])
  client    User       @relation("ClientRatings", fields: [clientId], references: [id])
  staff     User       @relation("StaffRatings", fields: [staffId], references: [id])
  workspace Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([clientId])
  @@index([staffId])
  @@index([workspaceId])
}

// ----------------------------------------------------------------------
// Tracking & Analytics Models
// ----------------------------------------------------------------------

model Session {
  id          String    @id @default(cuid())
  userId      String?
  workspaceId String?
  ipAddress   String?
  countryCode String?
  city        String?
  timezone    String?
  userAgent   String?
  startTime   DateTime  @default(now())
  endTime     DateTime?
  durationSec Int? // Thời lượng phiên làm việc (giây)

  user      User?      @relation(fields: [userId], references: [id])
  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  events    Event[]

  @@index([workspaceId, countryCode])
  @@index([startTime])
}

model Event {
  id          String   @id @default(cuid())
  sessionId   String
  userId      String?
  eventType   String // Phân loại: PAGE_VIEW, BUTTON_CLICK, TASK_START, REVISION...
  featureName String // Định danh tính năng cụ thể
  metadata    Json? // Cấu trúc linh hoạt lưu trữ toạ độ, chuỗi cấu hình, điểm đánh giá
  createdAt   DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([featureName])
}

model UserPresence {
  userId        String   @id
  status        String   @default("OFFLINE") // Trạng thái: ONLINE, OFFLINE, AWAY
  lastHeartbeat DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, lastHeartbeat])
}

// ----------------------------------------------------------------------
// Quality & Error Rating Models
// ----------------------------------------------------------------------

model ErrorDictionary {
  id          String   @id @default(uuid())
  code        String   @unique
  description String
  severity    Int      @default(3) // 1: Đặc biệt nghiêm trọng, 2: Trung bình, 3: Nhẹ
  penalty     Int      @default(1) // Trọng số điểm phạt
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isActive    Boolean  @default(true)

  logs ErrorLog[]
}

model ErrorLog {
  id              String   @id @default(uuid())
  taskId          String
  userId          String
  errorId         String
  frequency       Int      @default(1) // Số lần vi phạm lỗi này trong 1 task
  calculatedScore Int // frequency * ErrorDictionary.penalty
  detectedById    String // Manager người bắt lỗi
  createdAt       DateTime @default(now())
  workspaceId     String

  task       Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user       User            @relation("UserErrorLogs", fields: [userId], references: [id], onDelete: Cascade)
  error      ErrorDictionary @relation(fields: [errorId], references: [id])
  detectedBy User            @relation("UserDetectedErrors", fields: [detectedById], references: [id])
  workspace  Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  profile    Profile?        @relation(fields: [profileId], references: [id])
  profileId  String?

  @@index([taskId])
  @@index([userId])
  @@index([workspaceId])
  @@index([createdAt])
}

model MonthlyRank {
  id            String   @id @default(uuid())
  userId        String
  month         Int
  year          Int
  workspaceId   String
  totalTasks    Int      @default(0)
  totalPenalty  Int      @default(0)
  errorRate     Float    @default(0)
  rank          String   @default("UNRANKED") // S, A, B, C, D, UNRANKED
  isLocked      Boolean  @default(false)
  payrollLockId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User         @relation("UserMonthlyRanks", fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  payrollLock PayrollLock? @relation(fields: [payrollLockId], references: [id])
  profile     Profile?     @relation(fields: [profileId], references: [id])
  profileId   String?

  @@unique([userId, month, year, workspaceId])
  @@index([rank])
}

model ScheduleRule {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  profileId   String
  dayOfWeek   Int // 0=Sun, 1=Mon, ... 6=Sat
  startTime   String // HH:mm
  endTime     String // HH:mm
  timezone    String   @default("Asia/Ho_Chi_Minh")
  isActive    Boolean  @default(true)
  updatedById String?
  version     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  profile   Profile   @relation(fields: [profileId], references: [id])

  @@unique([userId, dayOfWeek, workspaceId, profileId])
  @@index([userId, dayOfWeek])
  @@index([workspaceId])
}

model ScheduleException {
  id          String                @id @default(uuid())
  userId      String
  workspaceId String
  profileId   String
  date        DateTime // Normalized to UTC midnight
  startTime   String // HH:mm
  endTime     String // HH:mm
  type        ScheduleExceptionType
  reason      String?
  timezone    String                @default("Asia/Ho_Chi_Minh")
  updatedById String?
  version     Int                   @default(0)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  profile   Profile   @relation(fields: [profileId], references: [id])

  @@index([userId, date])
  @@index([workspaceId])
}

model DailyAvailability {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  profileId   String
  date        DateTime // Normalized to UTC midnight
  schedule    Json // Array of 24 strings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  profile   Profile   @relation(fields: [profileId], references: [id])

  @@unique([userId, date, workspaceId, profileId])
  @@index([userId, date])
  @@index([workspaceId])
}

enum ScheduleExceptionType {
  BLOCK
  ADD
}

model PriceTemplate {
  id          String   @id @default(uuid())
  name        String
  priceUSD    Float?
  wageVND     Float?
  sortOrder   Int      @default(0)
  workspaceId String
  createdAt   DateTime @default(now())

  @@index([workspaceId])
}

// ----------------------------------------------------------------------
// Tag & Marketplace Models
// ----------------------------------------------------------------------

enum ClaimSource {
  ADMIN
  MARKET
}

model TagCategory {
  id          String   @id @default(uuid())
  name        String
  profileId   String
  userId      String
  // workspaceId optional during transition. Backfill via SQL migration,
  // then make required in a follow-up. Until then `getWorkspacePrisma`
  // will treat null as "any workspace" and queries should filter explicitly.
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile   Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  taskTags  TaskTag[]

  @@index([profileId])
  @@index([userId])
  @@index([workspaceId])
}

model TaskTag {
  id            String @id @default(uuid())
  taskId        String
  tagCategoryId String

  task        Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tagCategory TagCategory @relation(fields: [tagCategoryId], references: [id], onDelete: Cascade)

  @@unique([taskId, tagCategoryId])
  @@index([taskId])
  @@index([tagCategoryId])
}

// ----------------------------------------------------------------------
// Chat & Messaging Models
// ----------------------------------------------------------------------

enum ContactStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

enum ConversationType {
  DIRECT
  GROUP
  TASK
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
  ANNOUNCEMENT
}

enum NotificationType {
  // Chat
  NEW_MESSAGE
  MENTION
  GROUP_MEMBER_ADDED
  GROUP_MEMBER_REMOVED
  GROUP_MEMBER_LEFT
  GROUP_DELETED
  // Task
  TASK_ASSIGNED
  TASK_UNASSIGNED
  TASK_STATUS_CHANGED
  TASK_DEADLINE_APPROACHING
  TASK_OVERDUE
  TASK_COMMENT
}

model Notification {
  id             String           @id @default(uuid())
  userId         String
  type           NotificationType
  title          String
  body           String           @db.Text
  avatarUrl      String?
  isRead         Boolean          @default(false)
  isArchived     Boolean          @default(false)
  // Source links (nullable, depends on type)
  conversationId String?
  messageId      String?
  taskId         String?
  actorId        String?
  // Flexible metadata (group name, task title, oldStatus, newStatus, messageCount, ...)
  metadata       Json?
  // Delivery tracking — kept for future Push/Email phases
  pushSentAt     DateTime?
  emailSentAt    DateTime?
  createdAt      DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, type, createdAt])
  @@index([userId, conversationId, type, createdAt])
}

model NotificationPreference {
  id              String   @id @default(uuid())
  userId          String   @unique
  emailEnabled    Boolean  @default(true)
  emailDigestMode String   @default("REALTIME") // REALTIME | HOURLY | DAILY | OFF
  quietHoursStart Int? // 0-23 UTC hour, null = no quiet hours
  quietHoursEnd   Int? // 0-23 UTC hour
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Contact {
  id          String        @id @default(uuid())
  requesterId String
  receiverId  String
  status      ContactStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  requester User @relation("ContactRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User @relation("ContactReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
  @@index([receiverId, status])
  @@index([requesterId, status])
}

model Conversation {
  id          String           @id @default(uuid())
  type        ConversationType
  name        String?
  avatarUrl   String?
  taskId      String?          @unique
  workspaceId String?
  createdById String
  deletedFor  Json? // { userId: ISOdate } per-participant soft delete
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  task         Task?                     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdBy    User                      @relation("ConversationCreator", fields: [createdById], references: [id])
  participants ConversationParticipant[]
  messages     Message[]
  pins         MessagePin[]

  @@index([type, workspaceId])
  @@index([taskId])
}

model ConversationParticipant {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  role           String   @default("MEMBER")
  lastReadAt     DateTime @default(now())
  joinedAt       DateTime @default(now())
  isMuted        Boolean  @default(false)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, lastReadAt])
}

model Message {
  id                          String      @id @default(uuid())
  conversationId              String
  senderId                    String
  content                     String?     @db.Text
  type                        MessageType @default(TEXT)
  fileUrl                     String?
  fileName                    String?
  fileSize                    Int?
  replyToId                   String?
  isEdited                    Boolean     @default(false)
  isDeleted                   Boolean     @default(false)
  editedAt                    DateTime?
  deletedAt                   DateTime?
  viewOnce                    Boolean     @default(false)
  viewedBy                    Json? // { userId: ISOdate } map of who viewed
  deletedForUsers             Json? // { userId: ISOdate } per-user "delete for me" hide
  isImportant                 Boolean     @default(false) // sender flagged as needs response
  mentions                    Json? // string[] of userIds mentioned via @
  forwardedFromMessageId      String?
  forwardedFromConversationId String?
  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt

  conversation Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                 @relation("MessageSender", fields: [senderId], references: [id])
  replyTo      Message?             @relation("MessageReply", fields: [replyToId], references: [id])
  replies      Message[]            @relation("MessageReply")
  reactions    MessageReaction[]
  readReceipts MessageReadReceipt[]
  pin          MessagePin?

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model MessagePin {
  id             String   @id @default(uuid())
  messageId      String   @unique
  conversationId String
  pinnedById     String
  pinnedAt       DateTime @default(now())

  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  pinnedBy     User         @relation(fields: [pinnedById], references: [id])

  @@index([conversationId, pinnedAt])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model MessageReadReceipt {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
}
