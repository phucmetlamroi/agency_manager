  "_sourceBucketsNote": "Exports/Final are NOT source-buckets — they hold deliverables (FINAL role). See spec §3.2.",
  "status": {
    "EXCLUDED": [
      "no use",
      "non use",
      "not use",
      "dont use",
      "don't use",
      "do not use",
      "unused"
    ],
    "REPLACEMENT": ["replacement", "replaced"],
    "PENDING": [
      "future edits",
      "future edit",
      "wip",
      "tbc",
      "draft",
      "placeholder"
    ],
    "FINAL": ["final", "approved", "master", "delivered"]
  },
  "rawDumpPatterns": [
    "^(nested\\s*sequence|sequence|comp|render|export|clip|untitled)\\s*\\d+",
    "^(dsc|img|mvi|gopr|dji|c)\\d{3,5}\\b",
    "^\\d+$"
  ],
  "_rawDumpNote": "Default names from cameras (DSC0001, C0017) and NLE (Nested Sequence 247, Comp 12, Untitled 03). Files matching these go to the Raw tray, not on the map.",
  "videoExt": ["mp4", "mov", "m4v", "avi", "mkv", "mxf", "webm"],
  "audioExt": ["mp3", "wav", "aif", "aiff", "m4a", "flac"],
  "imageExt": ["jpg", "jpeg", "png", "gif", "tif", "tiff", "webp", "heic"]
