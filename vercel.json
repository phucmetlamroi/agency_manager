{
    "functions": {
        "api/*.py": {
            "maxDuration": 10
        },
        "src/app/api/**/*.ts": {
            "maxDuration": 30
        },
        "src/app/api/invoices/**/*.ts": {
            "maxDuration": 60
        }
    },
    "crons": [
        {
            "path": "/api/cron/send-digest",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/cron/check-deadline",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/cron/cleanup-notifications",
            "schedule": "0 2 * * *"
        }
    ]
}