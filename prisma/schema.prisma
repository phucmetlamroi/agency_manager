// ─────────────────────────────────────────────────────────────────────
//  Auth Phase 1: signup / login email-only / forgot password / migration
// ─────────────────────────────────────────────────────────────────────

/// Token gửi qua email để xác thực địa chỉ email (signup/migration) HOẶC password reset.
/// Lưu HASH (SHA-256) của raw token; raw token chỉ xuất hiện trong link email/response.
///
/// Security note: `purpose` field BẮT BUỘC để tránh logic confusion —
/// query email-verification flow KHÔNG được vô tình match password reset token và ngược lại.
/// Mọi query MUST filter theo `purpose`.
model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // SHA-256 hex của raw token
  // Values: "EMAIL_VERIFICATION" | "PASSWORD_RESET" | "EMAIL_MIGRATION"
  purpose   String    @default("EMAIL_VERIFICATION")
  email     String    // Email liên quan (có thể khác User.email khi đổi)
  expiresAt DateTime  // = createdAt + 24h (verification) hoặc 5 phút (password reset)
  usedAt    DateTime? // null nếu chưa verify
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([userId, purpose])
  @@index([expiresAt])
}

/// OTP 6 chữ số cho luồng quên mật khẩu / xác thực email migration.
/// Lưu HASH (SHA-256) của OTP plaintext; KHÔNG bao giờ lưu plaintext.
///
/// Security note: `purpose` field BẮT BUỘC để tránh token confusion —
/// password reset OTP KHÔNG được vô tình match email migration query và ngược lại.
model PasswordResetOTP {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  otpHash       String    // SHA-256 hex của 6-digit OTP
  // Values: "PASSWORD_RESET" | "EMAIL_MIGRATION"
  purpose       String    @default("PASSWORD_RESET")
  email         String    // Snapshot email tại thời điểm tạo (chống email-change attack)
  expiresAt     DateTime  // = createdAt + 10 phút
  attemptCount  Int       @default(0) // Tăng mỗi lần verify sai; >= 5 → invalidate
  consumedAt    DateTime? // Đặt khi user nhập đúng OTP và bắt đầu reset password
  invalidatedAt DateTime? // Đặt khi vượt quá 5 lần thử / superseded
  ipAddress     String?
  createdAt     DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, purpose])
  @@index([expiresAt])
}

/// Lịch sử các lần thử đăng nhập (success/fail) — phục vụ:
///   - Account lockout (đếm 5 fail trong 15 phút sliding window)
///   - Security audit ("ai đã login từ IP nào?")
///   - Anti-fraud (Phase 5+ correlate với device fingerprint)
model LoginAttempt {
  id         String    @id @default(uuid())
  userId     String?   // null nếu user_not_found (chống enumeration: vẫn log)
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  emailTried String    // Lowercase. Có thể là email hoặc username (transition mode).
  success    Boolean
  failReason String?   // 'invalid_password' | 'user_not_found' | 'account_locked' | 'email_not_verified' | 'rate_limited'
  ipAddress  String
  userAgent  String?
  createdAt  DateTime  @default(now())

  @@index([emailTried, createdAt])
  @@index([ipAddress, createdAt])
  @@index([userId, createdAt])
}

// ──────────────────────────────────────────────────────────────────────────────
// [Quick Create] OAuth integration tokens — Dropbox & Google Drive per-user
// ──────────────────────────────────────────────────────────────────────────────

/// Per-user OAuth tokens for cloud storage providers (Dropbox, Google Drive).
/// Tokens are AES-256-GCM encrypted at rest via INTEGRATION_TOKEN_SECRET env var.
/// Each user can connect ONE provider per workspace (unique constraint).
model IntegrationToken {
  id           String    @id @default(uuid())
  userId       String
  workspaceId  String
  provider     String    // "dropbox" | "google_drive"
  accessToken  String    // AES-256-GCM encrypted
  refreshToken String?   // AES-256-GCM encrypted (nullable — Dropbox offline access)
  expiresAt    DateTime? // Token expiry; null = never expires (Dropbox legacy)
  accountEmail String?   // Display: "Connected as user@gmail.com"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId, provider])
  @@index([workspaceId, provider])
}

// ──────────────────────────────────────────────────────────────────────────────
// [Quick Create] Flexible pricing rules — per-client or workspace-default
// ──────────────────────────────────────────────────────────────────────────────

/// Pricing rules for automatic task pricing in Quick Create mode.
/// Supports multiple rule types via JSON config:
///   - "flat":             { priceUSD, wageVND }
///   - "per_minute":       { ratePerMinuteUSD, wagePerMinuteVND, minimumUSD, minimumVND }
///   - "tiered_duration":  { tiers: [{ maxSeconds, priceUSD, wageVND, extraPerBlock?, ... }] }
///   - "custom":           { formula, variables } (future extensibility)
/// clientId=null means workspace-wide default rule.
model PricingRule {
  id          String   @id @default(uuid())
  name        String   // "Dr. Marwan Standard", "Default Short/Long"
  clientId    Int?     // null = workspace default rule
  workspaceId String
  profileId   String
  ruleType    String   // "flat" | "per_minute" | "tiered_duration" | "custom"
  config      Json     // Flexible rule config — schema depends on ruleType
  isDefault   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, clientId])
  @@index([workspaceId, isDefault])
}

// ============================================================
// KNOWLEDGE HUB — unified Channel model (chat + forum + wiki + task-chat)
// Every row carries workspaceId + profileId → getWorkspacePrisma auto-scopes
// them. DO NOT add these models to bypassModels / noProfileModels.
// ============================================================

enum ChannelType {
  TEXT // realtime team chat stream
  FORUM // post-based (UI deferred)
  WIKI // container for wiki pages
  TASK // auto-created, attached to one task
}

enum ChannelVisibility {
  PUBLIC // all workspace members can view
  PRIVATE // only explicit ChannelMember rows
}

enum PostPolicy {
  EVERYONE // any viewer can post
  ADMINS_ONLY // only workspace OWNER/ADMIN (or channel MODERATOR) can post
}

enum ChannelRole {
  MEMBER
  MODERATOR
}

model Category {
  id          String   @id @default(cuid())
  workspaceId String
  profileId   String
  name        String
  position    Int      @default(0)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channels  Channel[]

  @@index([workspaceId])
}

model Channel {
  id          String            @id @default(cuid())
  workspaceId String
  profileId   String
  categoryId  String?
  name        String
  description String?
  type        ChannelType       @default(TEXT)
  visibility  ChannelVisibility @default(PUBLIC)
  postPolicy  PostPolicy        @default(EVERYONE)
  position    Int               @default(0)
  // Task linkage: when set, this channel is the discussion thread for one task
  taskId      String?           @unique
  // [Client Portal] when set, this is the private client↔team message channel for one Client
  clientId    Int?
  // [Hub member-based] channel creator/owner — full MANAGE rights; SetNull if the account is removed
  createdById String?
  // [Chat Phase 3] per-channel rate limit (seconds between posts); owner/mod bypass
  slowModeSeconds Int           @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category  Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  task      Task?           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  creator   User?           @relation("ChannelCreator", fields: [createdById], references: [id], onDelete: SetNull)
  messages  Message[]
  members   ChannelMember[]
  overwrites ChannelOverwrite[]
  wikiPages WikiPage[]

  @@index([workspaceId, type])
  @@index([categoryId])
  @@index([clientId])
}

model Message {
  id          String    @id @default(cuid())
  workspaceId String
  profileId   String
  channelId   String
  authorId    String
  content     String    @db.Text
  // Threading (Slack-style): null = top-level; else points to parent (root) message
  parentId    String?
  replyCount  Int       @default(0)
  editedAt    DateTime?
  deletedAt   DateTime? // soft delete
  // [Chat] Pinned messages: pinnedAt set = pinned; pinnedById = who pinned it (moderation act)
  pinnedAt    DateTime?
  pinnedById  String?
  createdAt   DateTime  @default(now())

  channel     Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author      User         @relation("MessageAuthor", fields: [authorId], references: [id])
  pinnedBy    User?        @relation("MessagePinnedBy", fields: [pinnedById], references: [id], onDelete: SetNull)
  parent      Message?     @relation("MessageThread", fields: [parentId], references: [id], onDelete: SetNull)
  replies     Message[]    @relation("MessageThread")
  reactions   Reaction[]
  mentions    Mention[]
  attachments Attachment[]
  linkPreviews LinkPreview[]

  @@index([channelId, createdAt])
  @@index([channelId, pinnedAt])
  @@index([parentId])
}

model Reaction {
  id          String   @id @default(cuid())
  workspaceId String
  profileId   String
  messageId   String
  userId      String
  emoji       String
  createdAt   DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model Mention {
  id          String   @id @default(cuid())
  workspaceId String
  profileId   String
  messageId   String
  userId      String
  createdAt   DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([messageId])
}

model ChannelMember {
  id          String      @id @default(cuid())
  workspaceId String
  profileId   String
  channelId   String
  userId      String
  role        ChannelRole @default(MEMBER)
  lastReadAt  DateTime?
  muted       Boolean     @default(false)
  joinedAt    DateTime    @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
