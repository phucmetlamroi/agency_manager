generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id        String   @id @default(uuid())
  name      String
  bannerUrl String?
  logoUrl   String?
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  workspaces   Workspace[]
  tasks        Task[]
  clients      Client[]
  projects     Project[]
  invoices     Invoice[]
  payrolls     Payroll[]
  bonuses      MonthlyBonus[]
  payrollLocks PayrollLock[]
  metrics      PerformanceMetric[]
  agencies           Agency[]
  errorLogs          ErrorLog[]
  monthlyRanks       MonthlyRank[]
  scheduleRules      ScheduleRule[]
  scheduleExceptions ScheduleException[]
  dailyAvailabilities DailyAvailability[]
  profileAccesses     ProfileAccess[]
  accessRequests      ProfileAccessRequest[] @relation("TargetProfileRequests")
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  profileId   String?

  members            WorkspaceMember[]
  tasks              Task[]
  clients            Client[]
  scheduleRules      ScheduleRule[]
  scheduleExceptions ScheduleException[]
  dailyAvailabilities DailyAvailability[]
  projects     Project[]
  invoices     Invoice[]
  payrolls     Payroll[]
  bonuses      MonthlyBonus[]
  payrollLocks PayrollLock[]
  metrics      PerformanceMetric[]
  feedbacks    Feedback[]
  errorLogs    ErrorLog[]
  monthlyRanks MonthlyRank[]
  ratings      Rating[]
  sessions     Session[]

  profile Profile? @relation(fields: [profileId], references: [id])

  @@index([name])
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  role        String   @default("MEMBER") // "OWNER", "ADMIN", "MEMBER", "GUEST"
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
}

model User {
  id                String              @id @default(uuid())
  username          String              @unique
  password          String
  createdAt         DateTime            @default(now())
  reputation        Int                 @default(100)
  isTreasurer       Boolean             @default(false)
  hasAcceptedTerms  Boolean             @default(false)
  termsAcceptedAt   DateTime?
  email             String?
  nickname          String?
  phoneNumber       String?
  paymentAccountNum String?
  paymentBankName   String?
  paymentQrUrl      String?
  agencyId          String?
  profileId         String?
  role              UserRole            @default(USER)
  ownedAgency       Agency[]            @relation("AgencyOwner")
  bonuses           MonthlyBonus[]
  payrolls          Payroll[]
  metrics           PerformanceMetric[]
  tasks             Task[]              @relation("AssigneeTasks")

  agency            Agency?             @relation("AgencyMembers", fields: [agencyId], references: [id])
  workspaces        WorkspaceMember[]
  clientTasks       Task[]              @relation("UserClientTasks")
  clientProjects    Project[]           @relation("UserClientProjects")
  clientInvoices    Invoice[]           @relation("UserClientInvoices")
  clientRatings     Rating[]            @relation("ClientRatings")
  staffRatings      Rating[]            @relation("StaffRatings")
  errorLogs         ErrorLog[]          @relation("UserErrorLogs")
  detectedErrors    ErrorLog[]          @relation("UserDetectedErrors")
  monthlyRanks      MonthlyRank[]       @relation("UserMonthlyRanks")
  sessions          Session[]
  events            Event[]
  presence          UserPresence?
  scheduleRules      ScheduleRule[]
  scheduleExceptions ScheduleException[]
  dailyAvailabilities DailyAvailability[]
  profileAccesses     ProfileAccess[]
  accessRequests      ProfileAccessRequest[]
  approvedRequests    ProfileAccessRequest[] @relation("ApprovedBy")
  requestedRequests   ProfileAccessRequest[] @relation("RequestedBy")

  profile Profile? @relation(fields: [profileId], references: [id])
}

model ProfileAccess {
  id        String   @id @default(uuid())
  userId    String
  profileId String
  grantedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([userId, profileId])
}

model ProfileAccessRequest {
  id              String   @id @default(uuid())
  userId          String
  targetProfileId String
  requestedById   String
  approvedById    String?
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetProfile   Profile  @relation("TargetProfileRequests", fields: [targetProfileId], references: [id], onDelete: Cascade)
  requestedBy     User     @relation("RequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  approvedBy      User?    @relation("ApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@unique([userId, targetProfileId])
}



model Payroll {
  id          String    @id @default(uuid())
  userId      String
  month       Int
  year        Int
  baseSalary  Decimal   @default(0)
  bonus       Decimal   @default(0)
  totalAmount Decimal
  status      String    @default("UNPAID")
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  profileId   String?
  profile     Profile?  @relation(fields: [profileId], references: [id])

  @@unique([userId, month, year, workspaceId], name: "userId_month_year_workspaceId")
}

model Task {
  id               String            @id @default(uuid())
  title            String
  deadline         DateTime?
  value            Decimal           @default(0)
  status           String            @default("Đang thực hiện")
  type             String            @default("Short form")
  references       String?
  resources        String?
  notes_vi         String?
  notes_en         String?
  fileLink         String?
  assigneeId       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  productLink      String?
  isPenalized      Boolean           @default(false)
  exchangeRate     Decimal?          @default(25300)
  jobPriceUSD      Decimal?          @default(0)
  profitVND        Decimal?          @default(0)
  wageVND          Decimal?          @default(0)
  projectId        Int?
  clientId         Int?
  collectFilesLink String?
  submissionFolder String?
  frameUsername    String?
  framePassword    String?
  frameNote        String?           @default("Thông tin tài khoản frame dành cho trường hợp bạn bị out ra khỏi frame của team")
  assignedAgencyId String?
  version          Int               @default(0)
  invoiceId        String?
  invoiceStatus    InvoiceTaskStatus @default(UNBILLED)
  isArchived       Boolean           @default(false)
  feedbacks        Feedback[]
  errorLogs        ErrorLog[]
  invoiceItems     InvoiceItem[]
  assignedAgency   Agency?           @relation(fields: [assignedAgencyId], references: [id])
  assignee         User?             @relation("AssigneeTasks", fields: [assigneeId], references: [id])
  client           Client?           @relation(fields: [clientId], references: [id])
  clientUserId     String?
  clientUser       User?             @relation("UserClientTasks", fields: [clientUserId], references: [id])
  invoice          Invoice?          @relation(fields: [invoiceId], references: [id])
  project          Project?          @relation(fields: [projectId], references: [id])
  workspaceId      String?
  workspace        Workspace?        @relation(fields: [workspaceId], references: [id])
  profileId        String?
  profile          Profile?          @relation(fields: [profileId], references: [id])
  rating           Rating?

  @@index([workspaceId, status])
  @@index([workspaceId, isArchived])
}

model MonthlyBonus {
  id                 String    @id @default(uuid())
  userId             String
  month              Int
  year               Int
  rank               Int
  revenue            Decimal
  executionTimeHours Float
  bonusAmount        Decimal
  calculatedAt       DateTime  @default(now())
  user               User      @relation(fields: [userId], references: [id])
  workspaceId        String
  workspace          Workspace @relation(fields: [workspaceId], references: [id])
  profileId          String?
  profile            Profile?  @relation(fields: [profileId], references: [id])

  @@unique([userId, month, year, workspaceId], name: "userId_month_year_workspaceId")
}

model PayrollLock {
  id          String    @id @default(uuid())
  month       Int
  year        Int
  isLocked    Boolean   @default(false)
  lockedAt    DateTime  @default(now())
  lockedBy    String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  profileId   String?
  profile     Profile?  @relation(fields: [profileId], references: [id])
  monthlyRanks MonthlyRank[]

  @@unique([month, year, workspaceId], name: "month_year_workspaceId")
}

model Client {
  id             Int        @id @default(autoincrement())
  name           String
  parentId       Int?
  aiScore        Decimal    @default(0)
  frictionIndex  Decimal    @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  inputQuality   Int        @default(3)
  paymentRating  Int        @default(3)
  tier           ClientTier @default(standard)
  depositBalance Decimal    @default(0)
  parent         Client?    @relation("ClientHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  subsidiaries   Client[]   @relation("ClientHierarchy")
  invoices       Invoice[]
  projects       Project[]
  tasks          Task[]
  workspaceId    String?
  workspace      Workspace? @relation(fields: [workspaceId], references: [id])
  profileId      String?
  profile        Profile?   @relation(fields: [profileId], references: [id])
}

model Project {
  id           Int        @id @default(autoincrement())
  name         String
  code         String?
  clientId     Int
  createdAt    DateTime   @default(now())
  feedbacks    Feedback[]
  client       Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks        Task[]
  workspaceId  String?
  workspace    Workspace? @relation(fields: [workspaceId], references: [id])
  clientUserId String?
  clientUser   User?      @relation("UserClientProjects", fields: [clientUserId], references: [id])
  profileId    String?
  profile      Profile?   @relation(fields: [profileId], references: [id])
}

model Feedback {
  id          Int            @id @default(autoincrement())
  content     String
  projectId   Int?
  severity    Int            @default(1)
  createdAt   DateTime       @default(now())
  taskId      String?
  workspaceId String?
  type        FeedbackSource @default(CLIENT)
  project     Project?       @relation(fields: [projectId], references: [id])
  task        Task?          @relation(fields: [taskId], references: [id])
  workspace   Workspace?     @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
}

model PerformanceMetric {
  id                    String    @id @default(uuid())
  userId                String
  month                 Int
  year                  Int
  revenue               Decimal   @default(0)
  avgCompletionTime     Int       @default(0)
  onTimeRate            Float     @default(100)
  internalRevisionCount Int       @default(0)
  clientRevisionCount   Int       @default(0)
  score                 Float     @default(0)
  classification        String    @default("NORMAL")
  measuredAt            DateTime  @default(now())
  user                  User      @relation(fields: [userId], references: [id])
  workspaceId           String
  workspace             Workspace @relation(fields: [workspaceId], references: [id])
  profileId             String?
  profile               Profile?  @relation(fields: [profileId], references: [id])

  @@unique([userId, month, year, workspaceId], name: "userId_month_year_workspaceId")
}

model Agency {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  ownerId   String?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User?    @relation("AgencyOwner", fields: [ownerId], references: [id])
  tasks     Task[]
  members   User[]   @relation("AgencyMembers")

  profileId String?
  profile   Profile? @relation(fields: [profileId], references: [id])
}

model BillingProfile {
  id              String   @id @default(uuid())
  profileName     String
  beneficiaryName String
  bankName        String
  accountNumber   String
  swiftCode       String?
  address         String?
  isDefault       Boolean  @default(false)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
  notes           String?
}

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique
  clientId        Int
  createdBy       String
  issueDate       DateTime      @default(now())
  dueDate         DateTime?
  subtotalAmount  Decimal       @default(0)
  depositDeducted Decimal       @default(0)
  taxPercent      Decimal       @default(0)
  taxAmount       Decimal       @default(0)
  totalDue        Decimal       @default(0)
  status          InvoiceStatus @default(DRAFT)
  filePath        String?
  fileCreatedAt   DateTime?
  billingSnapshot Json
  clientSnapshot  Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  client          Client        @relation(fields: [clientId], references: [id])
  items           InvoiceItem[]
  tasks           Task[]
  workspaceId     String?
  workspace       Workspace?    @relation(fields: [workspaceId], references: [id])
  clientUserId    String?
  clientUser      User?         @relation("UserClientInvoices", fields: [clientUserId], references: [id])
  profileId       String?
  profile         Profile?      @relation(fields: [profileId], references: [id])
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  taskId      String?
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @default(0)
  amount      Decimal @default(0)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  task        Task?   @relation(fields: [taskId], references: [id])
}

enum FeedbackSource {
  INTERNAL
  CLIENT
}

enum ClientTier {
  DIAMOND
  GOLD
  SILVER
  WARNING
  standard
}

enum UserRole {
  ADMIN
  USER
  AGENCY_ADMIN
  CLIENT
  LOCKED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum InvoiceTaskStatus {
  UNBILLED
  INVOICED
}





model Rating {
  id                  String   @id @default(cuid())
  taskId              String   @unique
  clientId            String
  staffId             String
  creativeQuality     Decimal
  responsiveness      Decimal
  communication       Decimal
  qualitativeFeedback String?  @db.Text
  createdAt           DateTime @default(now())
  workspaceId         String?

  task      Task       @relation(fields: [taskId], references: [id])
  client    User       @relation("ClientRatings", fields: [clientId], references: [id])
  staff     User       @relation("StaffRatings", fields: [staffId], references: [id])
  workspace Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([clientId])
  @@index([staffId])
  @@index([workspaceId])
}

// ----------------------------------------------------------------------
// Tracking & Analytics Models
// ----------------------------------------------------------------------

model Session {
  id          String    @id @default(cuid())
  userId      String?
  workspaceId String?
  ipAddress   String?
  countryCode String?
  city        String?
  timezone    String?
  userAgent   String?
  startTime   DateTime  @default(now())
  endTime     DateTime?
  durationSec Int? // Thời lượng phiên làm việc (giây)

  user      User?      @relation(fields: [userId], references: [id])
  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  events    Event[]

  @@index([workspaceId, countryCode])
  @@index([startTime])
}

model Event {
  id          String   @id @default(cuid())
  sessionId   String
  userId      String?
  eventType   String // Phân loại: PAGE_VIEW, BUTTON_CLICK, TASK_START, REVISION...
  featureName String // Định danh tính năng cụ thể
  metadata    Json? // Cấu trúc linh hoạt lưu trữ toạ độ, chuỗi cấu hình, điểm đánh giá
  createdAt   DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([featureName])
}

model UserPresence {
  userId        String   @id
  status        String   @default("OFFLINE") // Trạng thái: ONLINE, OFFLINE, AWAY
  lastHeartbeat DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, lastHeartbeat])
}

// ----------------------------------------------------------------------
// Quality & Error Rating Models
// ----------------------------------------------------------------------

model ErrorDictionary {
  id          String   @id @default(uuid())
  code        String   @unique
  description String
  severity    Int      @default(3) // 1: Đặc biệt nghiêm trọng, 2: Trung bình, 3: Nhẹ
  penalty     Int      @default(1) // Trọng số điểm phạt
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isActive    Boolean  @default(true)

  logs ErrorLog[]
}

model ErrorLog {
  id              String   @id @default(uuid())
  taskId          String
  userId          String
  errorId         String
  frequency       Int      @default(1) // Số lần vi phạm lỗi này trong 1 task
  calculatedScore Int      // frequency * ErrorDictionary.penalty
  detectedById    String   // Manager người bắt lỗi
  createdAt       DateTime @default(now())
  workspaceId     String

  task        Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User            @relation("UserErrorLogs", fields: [userId], references: [id], onDelete: Cascade)
  error       ErrorDictionary @relation(fields: [errorId], references: [id])
  detectedBy  User            @relation("UserDetectedErrors", fields: [detectedById], references: [id])
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  profile     Profile?        @relation(fields: [profileId], references: [id])
  profileId   String?

  @@index([taskId])
  @@index([userId])
  @@index([workspaceId])
  @@index([createdAt])
}

model MonthlyRank {
  id             String   @id @default(uuid())
  userId         String
  month          Int
  year           Int
  workspaceId    String
  totalTasks     Int      @default(0)
  totalPenalty   Int      @default(0)
  errorRate      Float    @default(0)
  rank           String   @default("UNRANKED") // S, A, B, C, D, UNRANKED
  isLocked       Boolean  @default(false)
  payrollLockId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user        User         @relation("UserMonthlyRanks", fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  payrollLock PayrollLock? @relation(fields: [payrollLockId], references: [id])
  profile     Profile?     @relation(fields: [profileId], references: [id])
  profileId   String?

  @@unique([userId, month, year, workspaceId])
  @@index([rank])
}

model ScheduleRule {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  profileId   String
  dayOfWeek   Int      // 0=Sun, 1=Mon, ... 6=Sat
  startTime   String   // HH:mm
  endTime     String   // HH:mm
  timezone    String   @default("Asia/Ho_Chi_Minh")
  isActive    Boolean  @default(true)
  updatedById String?
  version     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  profile   Profile   @relation(fields: [profileId], references: [id])

  @@unique([userId, dayOfWeek, workspaceId, profileId])
  @@index([userId, dayOfWeek])
  @@index([workspaceId])
}

model ScheduleException {
  id          String                @id @default(uuid())
  userId      String
  workspaceId String
  profileId   String
  date        DateTime              // Normalized to UTC midnight
  startTime   String                // HH:mm
  endTime     String                // HH:mm
  type        ScheduleExceptionType
  reason      String?
  timezone    String                @default("Asia/Ho_Chi_Minh")
  updatedById String?
  version     Int                   @default(0)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  profile   Profile   @relation(fields: [profileId], references: [id])

  @@index([userId, date])
  @@index([workspaceId])
}

model DailyAvailability {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  profileId   String
  date        DateTime // Normalized to UTC midnight
  schedule    Json     // Array of 24 strings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  profile   Profile   @relation(fields: [profileId], references: [id])

  @@unique([userId, date, workspaceId, profileId])
  @@index([userId, date])
  @@index([workspaceId])
}

enum ScheduleExceptionType {
  BLOCK
  ADD
}
