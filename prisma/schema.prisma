generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id        String   @id @default(uuid())
  name      String
  bannerUrl String?
  logoUrl   String?
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // [Sprint B] Trial/subscription columns dropped — tất cả profile đều free + full features.

  // [Sprint Z+1] Soft-delete pattern (match Workspace).
  // status: "ACTIVE" | "SOFT_DELETED". hardDeleteAfter set khi soft-delete (NOW + 30d).
  // Cron /api/cron/hard-delete-profiles xóa khi hardDeleteAfter <= now → cascade workspaces.
  status          String    @default("ACTIVE")
  deletedAt       DateTime?
  hardDeleteAfter DateTime?

  users               User[]
  workspaces          Workspace[]
  tasks               Task[]
  clients             Client[]
  projects            Project[]
  invoices            Invoice[]
  payrolls            Payroll[]
  bonuses             MonthlyBonus[]
  payrollLocks        PayrollLock[]
  metrics             PerformanceMetric[]
  agencies            Agency[]
  errorLogs           ErrorLog[]
  monthlyRanks        MonthlyRank[]
  scheduleRules       ScheduleRule[]
  scheduleExceptions  ScheduleException[]
  dailyAvailabilities DailyAvailability[]
  profileAccesses     ProfileAccess[]
  accessRequests      ProfileAccessRequest[] @relation("TargetProfileRequests")
  billingProfiles     BillingProfile[]
  tagCategories       TagCategory[]
  // [Bonus Config] 1 cấu hình thưởng / team (profile), dùng lại mọi tháng.
  bonusConfig         BonusConfig?

  @@index([status, deletedAt])
}

model Workspace {
  id              String   @id @default(uuid())
  name            String
  description     String?
  marketplaceOpen Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  profileId       String?

  // Soft-delete (Phase 1 multi-workspace plan, Chapter 3)
  // status defaults to ACTIVE; SOFT_DELETED workspaces hidden from switcher
  // until hard-delete cron after `hardDeleteAfter`.
  status          String    @default("ACTIVE") // see WorkspaceStatus enum: ACTIVE | SUSPENDED | SOFT_DELETED
  deletedAt       DateTime?
  hardDeleteAfter DateTime?

  members             WorkspaceMember[]
  invitations         WorkspaceInvitation[]
  tasks               Task[]
  clients             Client[]
  scheduleRules       ScheduleRule[]
  scheduleExceptions  ScheduleException[]
  dailyAvailabilities DailyAvailability[]
  projects            Project[]
  invoices            Invoice[]
  payrolls            Payroll[]
  bonuses             MonthlyBonus[]
  payrollLocks        PayrollLock[]
  metrics             PerformanceMetric[]
  // [Sprint A removed] feedbacks relation — Feedback model deleted
  errorLogs           ErrorLog[]
  monthlyRanks        MonthlyRank[]
  ratings             Rating[]
  sessions            Session[]
  auditLogs           AuditLog[]
  tagCategories       TagCategory[]

  // [Quick Create] OAuth tokens + pricing rules per-workspace
  integrationTokens   IntegrationToken[]
  pricingRules        PricingRule[]

  // [Knowledge Hub] chat channels + categories + wiki pages
  channels   Channel[]
  categories Category[]
  wikiPages  WikiPage[]
  customRoles CustomRole[]

  profile Profile? @relation(fields: [profileId], references: [id])

  @@index([name])
  @@index([status, deletedAt])
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  role        String   @default("MEMBER") // see WorkspaceRole enum — kept as String until migration applied
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
}

model User {
  id                String              @id @default(uuid())
  username          String              @unique
  // [Username Handle] true = user đã chủ ý đặt username theo pattern mới
  // (signup mới hoặc đã complete migration modal). false = username cũ
  // (auto-derived từ email hoặc có dấu) → trigger migration modal khi user vào app.
  usernameSetByUser Boolean             @default(false)
  // [Google OAuth] password nullable — Google sign-in users have no password
  // (có thể đặt sau qua luồng "Quên mật khẩu"). googleId = Google account id
  // (canonical OAuth identity, dùng để nhận diện user quay lại). authProvider
  // = nguồn tạo tài khoản ("email" | "google") cho tracking/UI.
  password          String?
  googleId          String?             @unique
  authProvider      String?             @default("email")
  avatarUrl         String?
  createdAt         DateTime            @default(now())
  isTreasurer       Boolean             @default(false)
  hasAcceptedTerms  Boolean             @default(false)
  termsAcceptedAt   DateTime?
  email             String?
  nickname          String?
  phoneNumber       String?
  paymentAccountNum String?
  paymentBankName   String?
  paymentQrUrl      String?
  agencyId          String?
  profileId         String?
  role              UserRole            @default(USER)

  // ─── Auth Phase 1: signup / login email-only / forgot password ───
  // Display name (giữ Unicode tiếng Việt có dấu — KHÔNG sanitize)
  displayName                String?
  // Email verification flow
  emailVerified              Boolean   @default(false)
  emailVerifiedAt            DateTime?
  // Migration tracking cho user cũ (nhóm A/B/C trong backfill script)
  hasCompletedEmailMigration Boolean   @default(false)
  // Account lockout (5 fail / 15 phút)
  failedLoginAttempts        Int       @default(0)
  lockedUntil                DateTime?
  // Audit timestamps
  lastPasswordChangedAt      DateTime?
  lastLoginAt                DateTime?
  lastLoginIp                String?
  // Bump để invalidate tất cả JWT cũ (CVE-2025-29927 defense + reset password)
  sessionVersion             Int       @default(0)
  // Privacy: cho phép user thuộc Profile khác mời vào workspace của họ không?
  // Default true = backward compat. User có thể tắt trong Settings để chống
  // "spam invite từ unknown organizations" (audit finding #2.8).
  allowExternalInvites       Boolean   @default(true)
  // Audit fix #3.6: Link CLIENT-role user → Client record (portal access).
  // Trước đây client-portal-actions.ts match bằng `client.name === user.username`
  // → collision-prone. Giờ dùng FK explicit. Optional (Int?) cho user không phải CLIENT.
  clientId                   Int?
  client                     Client?   @relation("ClientPortalUser", fields: [clientId], references: [id], onDelete: SetNull)

  ownedAgency       Agency[]            @relation("AgencyOwner")
  bonuses           MonthlyBonus[]
  payrolls          Payroll[]
  metrics           PerformanceMetric[]
  tasks             Task[]              @relation("AssigneeTasks")
  // [Sprint P] Reverse relation for Task.assignedBy — track tasks user has
  // assigned to others (admin role). Used by email + notif routing.
  tasksAssignedBy   Task[]              @relation("TaskAssigner")

  agency                 Agency?                 @relation("AgencyMembers", fields: [agencyId], references: [id])
  workspaces             WorkspaceMember[]
  clientTasks            Task[]                  @relation("UserClientTasks")
  clientProjects         Project[]               @relation("UserClientProjects")
  clientInvoices         Invoice[]               @relation("UserClientInvoices")
  clientRatings          Rating[]                @relation("ClientRatings")
  staffRatings           Rating[]                @relation("StaffRatings")
  errorLogs              ErrorLog[]              @relation("UserErrorLogs")
  detectedErrors         ErrorLog[]              @relation("UserDetectedErrors")
  monthlyRanks           MonthlyRank[]           @relation("UserMonthlyRanks")
  sessions               Session[]
  events                 Event[]
  presence               UserPresence?
  notificationPreference NotificationPreference?
  scheduleRules          ScheduleRule[]
  scheduleExceptions     ScheduleException[]
  dailyAvailabilities    DailyAvailability[]
  profileAccesses        ProfileAccess[]
  accessRequests         ProfileAccessRequest[]
  approvedRequests       ProfileAccessRequest[]  @relation("ApprovedBy")
  requestedRequests      ProfileAccessRequest[]  @relation("RequestedBy")
  tagCategories          TagCategory[]
  auditLogsAsActor       AuditLog[]              @relation("AuditLogActor")
  auditLogsAsTarget      AuditLog[]              @relation("AuditLogUser")
  workspaceInvitesReceived WorkspaceInvitation[] @relation("WorkspaceInvitedUser")
  workspaceInvitesSent     WorkspaceInvitation[] @relation("WorkspaceInviter")

  // Auth Phase 1 relations
  emailVerificationTokens EmailVerificationToken[]
  passwordResetOTPs       PasswordResetOTP[]
  loginAttempts           LoginAttempt[]

  // [Quick Create] OAuth tokens for Dropbox / Google Drive per-user
  integrationTokens       IntegrationToken[]

  // Contact relations
  contactsSent         Contact[]                 @relation("ContactRequester")
  contactsReceived     Contact[]                 @relation("ContactReceiver")
  notifications        Notification[]

  // [Knowledge Hub] authored messages + reactions + mentions + memberships + wiki
  channelMessages    Message[]          @relation("MessageAuthor")
  channelReactions   Reaction[]
  channelMentions    Mention[]
  channelMemberships ChannelMember[]
  createdChannels    Channel[]          @relation("ChannelCreator")
  pinnedMessages     Message[]          @relation("MessagePinnedBy")
  customRoleMemberships CustomRoleMember[]
  wikiPages          WikiPage[]

  profile Profile? @relation(fields: [profileId], references: [id])

  // Auth Phase 1 indexes
  @@index([email])
  @@index([lockedUntil])
}

model ProfileAccess {
  id        String      @id @default(uuid())
  userId    String
  profileId String
  // [Sprint Z] Role-based access per profile (replaces binary access model).
  // OWNER = profile creator with full quyền (incl. xóa member).
  // ADMIN = invited + promoted, can create workspace + invite, can't remove.
  // USER  = invited (default), read-only.
  role      ProfileRole @default(USER)
  // [Sprint Z] grantedAt also serves as cutoff for ADMIN workspace access:
  // ADMIN sees workspaces with createdAt >= grantedAt automatically. Older
  // workspaces need explicit WorkspaceMember row granted by Owner.
  grantedAt DateTime    @default(now())
  // [Client membership] When role=CLIENT, the Client record this membership represents.
  clientId  Int?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  client  Client? @relation("ProfileAccessClient", fields: [clientId], references: [id], onDelete: SetNull)

  @@unique([userId, profileId])
  // [Sprint Z] Indices to speed up role+cutoff queries
  @@index([userId, grantedAt])
  @@index([profileId, role])
}

model ProfileAccessRequest {
  id              String   @id @default(uuid())
  userId          String
  targetProfileId String
  requestedById   String
  approvedById    String?
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetProfile Profile @relation("TargetProfileRequests", fields: [targetProfileId], references: [id], onDelete: Cascade)
  requestedBy   User    @relation("RequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  approvedBy    User?   @relation("ApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@unique([userId, targetProfileId])
}

model Payroll {
  id          String    @id @default(uuid())
  userId      String
  month       Int
  year        Int
  baseSalary  Decimal   @default(0)
  bonus       Decimal   @default(0)
  totalAmount Decimal
  status      String    @default("UNPAID")
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  profileId   String?
  profile     Profile?  @relation(fields: [profileId], references: [id])

  @@unique([userId, month, year, workspaceId], name: "userId_month_year_workspaceId")
}

model Task {
  id               String            @id @default(uuid())
  title            String
  deadline         DateTime?
  value            Decimal           @default(0)
  status           String            @default("Đang thực hiện")
  type             String            @default("Short form")
  references       String?
  resources        String?
  notes_vi         String?
  notes_en         String?
  fileLink         String?
  assigneeId       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  productLink      String?
  isPenalized      Boolean           @default(false)
  exchangeRate     Decimal?          @default(25300)
  jobPriceUSD      Decimal?          @default(0)
  profitVND        Decimal?          @default(0)
  wageVND          Decimal?          @default(0)
  projectId        Int?
  clientId         Int?
  collectFilesLink String?
  submissionFolder String?
  frameUsername    String?
  framePassword    String?
  frameNote        String?           @default("Thông tin tài khoản frame dành cho trường hợp bạn bị out ra khỏi frame của team")
  assignedAgencyId String?
  version          Int               @default(0)
  invoiceId        String?
  invoiceStatus    InvoiceTaskStatus @default(UNBILLED)
  isArchived       Boolean           @default(false)
  // [Sprint A removed] feedbacks relation — Feedback model deleted
  errorLogs        ErrorLog[]
  invoiceItems     InvoiceItem[]
  assignedAgency   Agency?           @relation(fields: [assignedAgencyId], references: [id])
  assignee         User?             @relation("AssigneeTasks", fields: [assigneeId], references: [id])
  client           Client?           @relation(fields: [clientId], references: [id])
  clientUserId     String?
  clientUser       User?             @relation("UserClientTasks", fields: [clientUserId], references: [id])
  invoice          Invoice?          @relation(fields: [invoiceId], references: [id])
  project          Project?          @relation(fields: [projectId], references: [id])
  workspaceId      String?
  workspace        Workspace?        @relation(fields: [workspaceId], references: [id])
  profileId        String?
  profile          Profile?          @relation(fields: [profileId], references: [id])
  duration         String?
  // [Client Portal] Client-facing review state, decoupled from internal `status`.
  // null = not in client review · AWAITING = cut ready for client · APPROVED · CHANGES (client requested changes)
  clientReview     String?
  clientFeedback   String?           // client's "request changes" note (separate from notes_vi)
  clientReviewedAt DateTime?         // when the client last approved / requested changes
  claimSource      ClaimSource       @default(ADMIN)
  claimedAt        DateTime?
  taskTags         TaskTag[]
  rating           Rating?
  // [Knowledge Hub] auto-created TASK-type discussion channel (1-1, lazy)
  channel          Channel?

  // [Sprint P] Track admin who assigned/created the task. Used for email +
  // in-app notification routing — when user starts/delivers a task, the
  // ASSIGNER (assignedBy) gets notified, not the user themselves.
  // Backward compat: nullable + onDelete: SetNull. Tasks created before
  // migration get backfilled to workspace OWNER.
  assignedById     String?
  assignedBy       User?             @relation("TaskAssigner", fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([workspaceId, isArchived])
  @@index([assignedById])
}

model MonthlyBonus {
  id                 String    @id @default(uuid())
  userId             String
  month              Int
  year               Int
  rank               Int
  revenue            Decimal
  executionTimeHours Float
  bonusAmount        Decimal
  // [Bonus Config] % đã áp cho hạng này (snapshot config tại thời điểm tính).
  bonusPercent       Decimal?  @default(0)
  calculatedAt       DateTime  @default(now())
  user               User      @relation(fields: [userId], references: [id])
  workspaceId        String
  workspace          Workspace @relation(fields: [workspaceId], references: [id])
  profileId          String?
  profile            Profile?  @relation(fields: [profileId], references: [id])

  @@unique([userId, month, year, workspaceId], name: "userId_month_year_workspaceId")
}

model PayrollLock {
  id           String        @id @default(uuid())
  month        Int
  year         Int
  isLocked     Boolean       @default(false)
  lockedAt     DateTime      @default(now())
  lockedBy     String
  workspaceId  String
  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  profileId    String?
  profile      Profile?      @relation(fields: [profileId], references: [id])
  monthlyRanks MonthlyRank[]

  @@unique([month, year, workspaceId], name: "month_year_workspaceId")
}

model Client {
  id             Int        @id @default(autoincrement())
  name           String
  parentId       Int?
  aiScore        Decimal    @default(0)
  frictionIndex  Decimal    @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  inputQuality   Int        @default(3)
  paymentRating  Int        @default(3)
  tier           ClientTier @default(standard)
  depositBalance Decimal    @default(0)
  parent         Client?    @relation("ClientHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  subsidiaries   Client[]   @relation("ClientHierarchy")
  invoices       Invoice[]
  projects       Project[]
  tasks          Task[]
  workspaceId    String?
  workspace      Workspace? @relation(fields: [workspaceId], references: [id])
  profileId      String?
  profile        Profile?   @relation(fields: [profileId], references: [id])
  // Audit fix #3.6: Reverse relation cho User.clientId
  // Một Client record có thể có 0..N portal users (vd 1 client = nhiều người
  // truy cập portal cùng).
  portalUsers    User[]     @relation("ClientPortalUser")
  // [Client membership] CLIENT-role ProfileAccess rows that represent this client.
  profileAccesses ProfileAccess[] @relation("ProfileAccessClient")

  // [Quick Create] Per-client pricing rules (null clientId = workspace default)
  pricingRules   PricingRule[]

  // [Soft-delete] Notion-style archive — mirror Profile/Workspace pattern.
  // status: "ACTIVE" | "SOFT_DELETED". Soft-delete hides the client (+ its
  // subsidiary subtree) from CRM lists/pickers but keeps tasks/invoices intact
  // and restorable from the Client Trash. hardDeleteAfter is reserved for a
  // future auto-purge cron (currently permanent-delete is manual-only).
  status          String    @default("ACTIVE")
  deletedAt       DateTime?
  hardDeleteAfter DateTime?

  @@index([status, deletedAt])
}

model Project {
  id           Int        @id @default(autoincrement())
  name         String
  code         String?
  clientId     Int
  createdAt    DateTime   @default(now())
  // [Sprint A removed] feedbacks relation — Feedback model deleted
  client       Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks        Task[]
  workspaceId  String?
  workspace    Workspace? @relation(fields: [workspaceId], references: [id])
  clientUserId String?
  clientUser   User?      @relation("UserClientProjects", fields: [clientUserId], references: [id])
  profileId    String?
  profile      Profile?   @relation(fields: [profileId], references: [id])
}

// [Sprint A removed] model Feedback — bảng đánh giá Client/Internal đã bỏ
// hoàn toàn (ManagerReviewChecklist + review-actions.ts cũng deleted).
// `prisma db push --accept-data-loss` sẽ DROP table này.

model PerformanceMetric {
  id                    String    @id @default(uuid())
  userId                String
  month                 Int
  year                  Int
  revenue               Decimal   @default(0)
  avgCompletionTime     Int       @default(0)
  onTimeRate            Float     @default(100)
  internalRevisionCount Int       @default(0)
  clientRevisionCount   Int       @default(0)
  score                 Float     @default(0)
  classification        String    @default("NORMAL")
  measuredAt            DateTime  @default(now())
  user                  User      @relation(fields: [userId], references: [id])
  workspaceId           String
  workspace             Workspace @relation(fields: [workspaceId], references: [id])
  profileId             String?
  profile               Profile?  @relation(fields: [profileId], references: [id])

  @@unique([userId, month, year, workspaceId], name: "userId_month_year_workspaceId")
}

model Agency {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  ownerId   String?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User?    @relation("AgencyOwner", fields: [ownerId], references: [id])
  tasks     Task[]
  members   User[]   @relation("AgencyMembers")

  profileId String?
  profile   Profile? @relation(fields: [profileId], references: [id])
}

model BillingProfile {
  id              String   @id @default(uuid())
  profileName     String
  beneficiaryName String
  bankName        String
  accountNumber   String
  swiftCode       String?
  address         String?
  currency        String?  @default("$")
  isDefault       Boolean  @default(false)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
  notes           String?
  profileId       String?
  profile         Profile? @relation(fields: [profileId], references: [id])
}

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique
  clientId        Int
  createdBy       String
  issueDate       DateTime      @default(now())
  dueDate         DateTime?
  subtotalAmount  Decimal       @default(0)
  depositDeducted Decimal       @default(0)
  taxPercent      Decimal       @default(0)
  taxAmount       Decimal       @default(0)
  totalDue        Decimal       @default(0)
  status          InvoiceStatus @default(DRAFT)
  filePath        String?
  fileCreatedAt   DateTime?
  billingSnapshot Json
  clientSnapshot  Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  client          Client        @relation(fields: [clientId], references: [id])
  items           InvoiceItem[]
  tasks           Task[]
  workspaceId     String?
  workspace       Workspace?    @relation(fields: [workspaceId], references: [id])
  clientUserId    String?
  clientUser      User?         @relation("UserClientInvoices", fields: [clientUserId], references: [id])
  profileId       String?
  profile         Profile?      @relation(fields: [profileId], references: [id])
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  taskId      String?
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @default(0)
  amount      Decimal @default(0)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  task        Task?   @relation(fields: [taskId], references: [id])
}

/// Workspace invitation — allows OWNER/ADMIN to invite users to a workspace.
/// Supports both in-profile direct adds and cross-profile invitations with
/// accept/decline flow. Token field enables future email-based invite links.
model WorkspaceInvitation {
  id            String   @id @default(uuid())
  workspaceId   String
  invitedUserId String?  // Target user ID (set for in-app invites)
  invitedEmail  String?  // Email for future email-based invites
  role          String   @default("MEMBER") // WorkspaceRole to assign on accept
  // [Client membership] cross-profile client invite: when true, accept creates a
  // ProfileAccess(role=CLIENT, clientId) instead of a WorkspaceMember.
  isClientInvite Boolean @default(false)
  clientId       Int?
  token         String   @unique @default(uuid()) // For email/link-based invites
  status        String   @default("PENDING") // PENDING | ACCEPTED | DECLINED | EXPIRED | REVOKED
  invitedById   String   // Who sent the invite
  message       String?  // Optional personal message from inviter
  expiresAt     DateTime // When the invitation expires
  respondedAt   DateTime? // When the invitee accepted/declined
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedUser User?     @relation("WorkspaceInvitedUser", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("WorkspaceInviter", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([workspaceId, invitedUserId, status]) // Prevent duplicate pending invites
  @@index([invitedUserId, status])
  @@index([workspaceId, status])
  @@index([token])
  @@index([expiresAt])
}

/// Immutable, append-only audit trail for security-sensitive workspace events.
/// IMPORTANT: code SHOULD only INSERT. Never expose update/delete via API.
/// At the DB level we will REVOKE UPDATE/DELETE on this table from the app
/// role in Phase 2 (see migration_audit_log_revoke.sql in deploy plan).
model AuditLog {
  id          BigInt   @id @default(autoincrement())
  // Auth Phase 1: workspaceId nullable để hỗ trợ auth events (SIGNUP, LOGIN_FAILED, ...)
  // không thuộc workspace nào. Workspace events giữ nguyên required workspaceId.
  workspaceId String?
  actorUserId String?
  // userId = target user (cho auth events: SIGNUP, PASSWORD_RESET_REQUESTED, EMAIL_VERIFIED).
  // Khác với actorUserId (người thực hiện action). Auth events thường userId = actorUserId.
  userId      String?
  action      String // e.g. 'workspace.created', 'auth.signup', 'auth.login_failed', 'auth.password_reset_requested'
  targetType  String // e.g. 'WorkspaceMember', 'Workspace', 'Task', 'User'
  targetId    String?
  beforeData  Json?
  afterData   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User?      @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  user      User?      @relation("AuditLogUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
