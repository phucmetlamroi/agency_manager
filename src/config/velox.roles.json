{
  "_comment": "Velox v4 deep-scan role dictionary. Spec §3.4 + Appendix A. Add aliases here, NOT in code. Per-client overrides live in velox.roles.<clientId>.json (merged on top of this base).",
  "schemaVersion": "velox-4.0",
  "separators": ["_", "|", "(", ")", "[", "]", "-", " "],
  "roles": [
    {
      "role": "HOOK",
      "priority": 100,
      "isSource": false,
      "isFinal": false,
      "aliases": [
        "hook",
        "hooks",
        "hk",
        "opener",
        "intro",
        "pattern interrupt",
        "pi"
      ],
      "letterForms": ["h"]
    },
    {
      "role": "BODY",
      "priority": 80,
      "isSource": false,
      "isFinal": false,
      "aliases": ["body", "main", "content", "demo", "mechanism"]
    },
    {
      "role": "CTA",
      "priority": 90,
      "isSource": false,
      "isFinal": false,
      "aliases": [
        "cta",
        "ctas",
        "cta's",
        "call to action",
        "main cta",
        "end card",
        "endcard",
        "outro",
        "offer"
      ]
    },
    {
      "role": "CALLOUT",
      "priority": 70,
      "isSource": false,
      "isFinal": false,
      "aliases": [
        "audience callout",
        "callout",
        "call out",
        "call-out"
      ]
    },
    {
      "role": "SCRIPT",
      "priority": 60,
      "isSource": false,
      "isFinal": false,
      "aliases": ["script", "vo script", "voiceover script"],
      "docExt": ["txt", "doc", "docx", "pdf"]
    },
    {
      "role": "CAPTION",
      "priority": 50,
      "isSource": false,
      "isFinal": false,
      "aliases": [
        "caption",
        "captions",
        "subs",
        "sub",
        "subtitle",
        "subtitles",
        "cc"
      ],
      "docExt": ["srt", "vtt"]
    },
    {
      "role": "FINAL",
      "priority": 40,
      "isSource": false,
      "isFinal": true,
      "aliases": [
        "final",
        "master",
        "ad",
        "video",
        "export",
        "approved",
        "delivered"
      ]
    }
  ],
  "sourceBuckets": [
    "a-roll",
    "a roll",
    "aroll",
    "b-roll",
    "b roll",
    "broll",
    "b-roll footage",
    "footage",
    "raw",
    "raw footage",
    "images",
    "image",
    "photos",
    "headshots",
    "stills",
    "assets",
    "audio",
    "music",
    "sfx",
    "project files",
    "project"
